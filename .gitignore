# ─────────────────────────────────────────────────────────────
# LearnLoop — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment — NEVER commit these
.env.local
.env*.local
.env

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/
dist/
build/

# Drizzle migrations (generated — do not commit generated files)
# lib/db/migrations/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts
