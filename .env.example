# ─────────────────────────────────────────────────────────────
# LearnLoop — Environment Variables Template
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Database (Neon PostgreSQL)
# Get from: neon.tech → your project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/learnloop?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/learnloop?sslmode=require

# NextAuth
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-character-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# YouTube Data API v3
# Get from: console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Anthropic Claude API
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# App URL (used for OAuth redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
